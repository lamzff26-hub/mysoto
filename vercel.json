{
  "framework": "laravel",
  "php": {
    "version": "8.3"
  },
  "public": "public",
  "buildCommand": "npm run vercel-build",
  "functions": {
    "api/index.php": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/storage/(.*)",
      "dest": "/storage/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_NAME": "@APP_NAME",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "DB_CONNECTION": "@DB_CONNECTION",
    "DB_HOST": "@DB_HOST",
    "DB_PORT": "@DB_PORT",
    "DB_DATABASE": "@DB_DATABASE",
    "DB_USERNAME": "@DB_USERNAME",
    "DB_PASSWORD": "@DB_PASSWORD"
  }
}
